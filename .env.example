# Dedicated Telegram bot created via @BotFather
TELEGRAM_BOT_TOKEN=
# Target group/chat id. Add the bot to the group, send a message, then use getUpdates or @RawDataBot to find it.
TELEGRAM_CHAT_ID=

# Optional shared secret for manually calling /api/check?secret=...
CRON_SECRET=

# Upstash Redis / Vercel KV-compatible REST credentials for dedupe state
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Public link shown in the dashboard hero
VITE_TELEGRAM_GROUP_URL=

# DeepL Free API key (500K chars/month) — get one at https://www.deepl.com/pro-api
DEEPL_API_KEY=
