# Dedicated Telegram bot created via @BotFather
TELEGRAM_BOT_TOKEN=
# Target channel username or numeric chat id. For the public channel, use @madridradar.
# The bot must be a channel admin with permission to post messages.
TELEGRAM_CHAT_ID=

# Optional shared secret for manually calling /api/check?secret=...
CRON_SECRET=

# Upstash Redis / Vercel KV-compatible REST credentials for dedupe state
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Public link shown in the dashboard hero
VITE_TELEGRAM_URL=

# DeepL Free API key (500K chars/month) — get one at https://www.deepl.com/pro-api
DEEPL_API_KEY=

# OpenRouter key + model for Telegram title translation + short English summary.
# Example free model: openrouter model slug that ends with :free (if currently available).
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/owl-alpha
OPENROUTER_FALLBACK_MODEL=openai/gpt-oss-20b:free
OPENROUTER_ARTICLE_MAX_CHARS=3500
